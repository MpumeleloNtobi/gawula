generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Geo + catalog
// ─────────────────────────────────────────────────────────────────────────────

model Complex {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  centroidLat          Float
  centroidLng          Float
  polygonGeoJson       Json?
  deliveryRadiusKm     Float    @default(5)
  baseDeliveryFeeCents Int      @default(4500)
  openingHours         Json
  layoutGraph          Json?
  status               String   @default("active")
  createdAt            DateTime @default(now())

  outlets Outlet[]
  riders  Rider[]
  shifts  Shift[]
  carts   Cart[]
  orders  Order[]
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  logoColor String?
  outlets   Outlet[]
}

model Outlet {
  id                String   @id @default(cuid())
  brandId           String
  complexId         String
  name              String
  locationInMall    String
  prepBufferMinutes Int      @default(2)
  commissionPct     Float    @default(0.13)
  status            String   @default("active")
  coverUrl          String?
  tagline           String?
  createdAt         DateTime @default(now())

  brand     Brand           @relation(fields: [brandId], references: [id])
  complex   Complex         @relation(fields: [complexId], references: [id])
  items     Item[]
  cartItems CartItem[]
  subOrders SubOrder[]
  settings  OutletSettings?
  reviews   Review[]
  promotions Promotion[]

  @@index([complexId])
  @@index([brandId])
}

model Item {
  id              String   @id @default(cuid())
  outletId        String
  name            String
  description     String
  priceCents      Int
  prepTimeMinutes Int      @default(5)
  imageUrl        String?
  available       Boolean  @default(true)
  category        String
  modifiers       Json
  createdAt       DateTime @default(now())
  archivedAt      DateTime?

  outlet     Outlet      @relation(fields: [outletId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([outletId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  phone             String?   @unique
  name              String?
  emailVerifiedAt   DateTime?
  mallPassActive    Boolean   @default(false)
  mallPassExpiresAt DateTime?
  createdAt         DateTime  @default(now())

  addresses          Address[]
  carts              Cart[]
  orders             Order[]
  resetTokens        PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  roleGrants         RoleGrant[]
  riderProfile       Rider?
  riderApplications  RiderApplication[]
  reviews            Review[]
}

model RoleGrant {
  id         String    @id @default(cuid())
  customerId String
  role       String
  complexId  String?
  outletId   String?
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, role])
  @@index([customerId])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Address {
  id           String   @id @default(cuid())
  customerId   String
  label        String?
  line1        String
  suburb       String?
  city         String
  postalCode   String?
  lat          Float
  lng          Float
  instructions String?
  createdAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  orders   Order[]

  @@index([customerId])
}

model Rider {
  id              String   @id @default(cuid())
  customerId      String   @unique
  name            String
  phone           String?
  vehicleType     String
  vehicleBrand    String?
  vehicleColour   String?
  vehicleReg      String?
  homeComplexId   String
  homeAddress     String?
  status          String   @default("offline")
  payoutAccountId String?
  createdAt       DateTime @default(now())

  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  homeComplex Complex           @relation(fields: [homeComplexId], references: [id])
  shifts      Shift[]
  trips       Trip[]
  application RiderApplication?

  @@index([homeComplexId])
}

model RiderApplication {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String
  areaId          String
  areaLabel       String
  waitlisted      Boolean   @default(false)
  vehicleType     String
  hasSmartphone   Boolean   @default(true)
  idNumber        String
  idFrontDocName  String?
  idBackDocName   String?
  selfieDocName   String?
  fullBodyDocName String?
  licenceDocName  String?
  stage           String    @default("submitted")
  rejectionReason String?
  reviewerId      String?
  riderId         String?   @unique
  customerId      String?
  decidedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rider    Rider?    @relation(fields: [riderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([stage])
  @@index([customerId])
}

model PartnerApplication {
  id                     String    @id @default(cuid())
  storeName              String
  description            String
  logoDocName            String?
  tradeType              String
  tradeTypeLabel         String
  locationName           String?
  address                String
  areaId                 String
  areaLabel              String
  waitlisted             Boolean   @default(false)
  firstName              String
  lastName               String
  storeEmail             String?
  storePhone             String?
  contactEmail           String
  contactPhone           String
  contactEmailVerifiedAt DateTime?
  soleProprietor         Boolean   @default(false)
  registrationNumber     String?
  registrationDocName    String?
  storefrontDocName      String?
  logoData               String?
  registrationData       String?
  storefrontData         String?
  stage                  String    @default("submitted")
  rejectionReason        String?
  reviewerId             String?
  decidedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  verificationTokens PartnerEmailVerificationToken[]

  @@index([stage])
  @@index([contactEmail])
}

model PartnerEmailVerificationToken {
  id            String    @id @default(cuid())
  applicationId String
  tokenHash     String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  application PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Shift {
  id        String    @id @default(cuid())
  riderId   String
  complexId String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  rider   Rider   @relation(fields: [riderId], references: [id])
  complex Complex @relation(fields: [complexId], references: [id])

  @@index([riderId])
  @@index([complexId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String
  name         String?
  complexId    String?
  outletId     String?
  totpSecret   String?
  createdAt    DateTime @default(now())

  reviewReplies ReviewReply[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Cart + Order
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String
  complexId  String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  customer Customer   @relation(fields: [customerId], references: [id])
  complex  Complex    @relation(fields: [complexId], references: [id])
  items    CartItem[]

  @@index([customerId])
}

model CartItem {
  id             String  @id @default(cuid())
  cartId         String
  outletId       String
  itemId         String
  qty            Int
  modifiers      Json
  notes          String?
  unitPriceCents Int

  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])

  @@index([cartId])
}

model Order {
  id                 String    @id @default(cuid())
  customerId         String
  complexId          String
  addressId          String
  status             String    @default("received")
  fulfilmentMode     String    @default("delivery")
  foodSubtotalCents  Int
  deliveryFeeCents   Int
  serviceFeeCents    Int
  tipCents           Int       @default(0)
  totalCents         Int
  surgeMultiplier    Float     @default(1.0)
  mallPassApplied    Boolean   @default(false)
  paymentIntentId    String?
  placedAt           DateTime  @default(now())
  promisedDeliveryAt DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  refundCents        Int       @default(0)
  refundedAt         DateTime?
  refundReason       String?

  customer  Customer        @relation(fields: [customerId], references: [id])
  complex   Complex         @relation(fields: [complexId], references: [id])
  address   Address         @relation(fields: [addressId], references: [id])
  subOrders SubOrder[]
  trip      Trip?
  auditLogs OrderAuditLog[]

  @@index([customerId])
  @@index([complexId])
  @@index([status])
}

model OrderAuditLog {
  id         String   @id @default(cuid())
  orderId    String
  actorId    String?
  actorEmail String?
  action     String
  reason     String?
  note       String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model SubOrder {
  id                String    @id @default(cuid())
  orderId           String
  outletId          String
  status            String    @default("pending")
  prepStartAt       DateTime?
  readyByAt         DateTime?
  readyAt           DateTime?
  riderCollectedAt  DateTime?
  pickupCode        String?
  pickupAttempts    Int       @default(0)
  pickupLockedUntil DateTime?
  cancelReason      String?
  foodSubtotalCents Int
  commissionCents   Int

  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  outlet     Outlet      @relation(fields: [outletId], references: [id])
  orderItems OrderItem[]
  tripStops  TripStop[]
  review     Review?

  @@index([orderId])
  @@index([outletId])
  @@index([status])
}

model OrderItem {
  id             String  @id @default(cuid())
  subOrderId     String
  itemId         String
  qty            Int
  fulfilledQty   Int?
  modifiers      Json
  notes          String?
  unitPriceCents Int
  totalCents     Int

  subOrder SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id])

  @@index([subOrderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Dispatch
// ─────────────────────────────────────────────────────────────────────────────

model Trip {
  id                String    @id @default(cuid())
  orderId           String    @unique
  riderId           String
  status            String    @default("claimed")
  claimedAt         DateTime  @default(now())
  pickupStartedAt   DateTime?
  deliveryStartedAt DateTime?
  deliveredAt       DateTime?
  distanceKm        Float?
  earningsCents     Int?

  order Order      @relation(fields: [orderId], references: [id])
  rider Rider      @relation(fields: [riderId], references: [id])
  stops TripStop[]

  @@index([riderId])
  @@index([status])
}

model TripStop {
  id          String    @id @default(cuid())
  tripId      String
  subOrderId  String
  sequence    Int
  etaAt       DateTime
  arrivedAt   DateTime?
  collectedAt DateTime?

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  subOrder SubOrder @relation(fields: [subOrderId], references: [id])

  @@unique([tripId, sequence])
  @@index([tripId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payouts
// ─────────────────────────────────────────────────────────────────────────────

model PayoutRun {
  id        String   @id @default(cuid())
  runDate   DateTime
  kind      String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  lines PayoutLine[]
}

model PayoutLine {
  id          String  @id @default(cuid())
  payoutRunId String
  partyId     String
  amountCents Int
  ref         String?

  run PayoutRun @relation(fields: [payoutRunId], references: [id], onDelete: Cascade)

  @@index([payoutRunId])
  @@index([partyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Storefront settings & reviews
// ─────────────────────────────────────────────────────────────────────────────

model OutletSettings {
  id               String   @id @default(cuid())
  outletId         String   @unique
  phone            String?
  email            String?
  addressLine      String?
  hoursJson        Json
  autoAcceptOrders Boolean  @default(false)
  pauseNewOrders   Boolean  @default(false)
  showPrepTime     Boolean  @default(true)
  allowTipping     Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  subOrderId String   @unique
  outletId   String
  customerId String
  rating     Int
  text       String
  createdAt  DateTime @default(now())

  subOrder SubOrder     @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  outlet   Outlet       @relation(fields: [outletId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  reply    ReviewReply?

  @@index([outletId])
  @@index([customerId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  authorId  String
  text      String
  createdAt DateTime @default(now())

  review Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author AdminUser @relation(fields: [authorId], references: [id])
}

model Promotion {
  id              String    @id @default(cuid())
  outletId        String
  type            String
  percentOff      Int       @default(0)
  amountOffCents  Int       @default(0)
  minSpendCents   Int       @default(0)
  buyItemId       String?
  getItemId       String?
  freeItemId      String?
  itemIds         String[]  @default([])
  category        String?
  buyQuantity     Int       @default(1)
  getQuantity     Int       @default(1)
  days            Int[]     @default([])
  startTime       String?
  endTime         String?
  paused          Boolean   @default(false)
  startAt         DateTime?
  endAt           DateTime?
  redemptionCount Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}
