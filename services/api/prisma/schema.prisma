generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Geo + catalog
// ─────────────────────────────────────────────────────────────────────────────

model Complex {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  centroidLat          Float
  centroidLng          Float
  polygonGeoJson       Json?
  deliveryRadiusKm     Float    @default(5)
  baseDeliveryFeeCents Int      @default(4500)
  openingHours         Json
  layoutGraph          Json?
  status               String   @default("active")
  createdAt            DateTime @default(now())

  outlets  Outlet[]
  riders   Rider[]
  shifts   Shift[]
  carts    Cart[]
  orders   Order[]
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  logoColor String?
  outlets   Outlet[]
}

model Outlet {
  id                  String   @id @default(cuid())
  brandId             String
  complexId           String
  name                String
  locationInMall      String
  prepBufferMinutes   Int      @default(2)
  commissionPct       Float    @default(0.13)
  status              String   @default("active")
  coverUrl            String?
  tagline             String?
  createdAt           DateTime @default(now())

  brand     Brand     @relation(fields: [brandId], references: [id])
  complex   Complex   @relation(fields: [complexId], references: [id])
  items     Item[]
  cartItems CartItem[]
  subOrders SubOrder[]

  @@index([complexId])
  @@index([brandId])
}

model Item {
  id              String  @id @default(cuid())
  outletId        String
  name            String
  description     String
  priceCents      Int
  prepTimeMinutes Int     @default(5)
  imageUrl        String?
  available       Boolean @default(true)
  category        String
  modifiers       Json
  createdAt       DateTime @default(now())

  outlet     Outlet      @relation(fields: [outletId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([outletId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id              String   @id @default(cuid())
  phone           String   @unique
  email           String?  @unique
  name            String?
  mallPassActive  Boolean  @default(false)
  mallPassExpiresAt DateTime?
  createdAt       DateTime @default(now())

  addresses Address[]
  carts     Cart[]
  orders    Order[]
}

model Address {
  id           String   @id @default(cuid())
  customerId   String
  label        String?
  line1        String
  suburb       String?
  city         String
  postalCode   String?
  lat          Float
  lng          Float
  instructions String?
  createdAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  orders   Order[]

  @@index([customerId])
}

model Rider {
  id              String   @id @default(cuid())
  name            String
  phone           String   @unique
  vehicleType     String
  homeComplexId   String
  status          String   @default("offline")
  payoutAccountId String?
  createdAt       DateTime @default(now())

  homeComplex Complex @relation(fields: [homeComplexId], references: [id])
  shifts      Shift[]
  trips       Trip[]

  @@index([homeComplexId])
}

model Shift {
  id        String    @id @default(cuid())
  riderId   String
  complexId String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  rider   Rider   @relation(fields: [riderId], references: [id])
  complex Complex @relation(fields: [complexId], references: [id])

  @@index([riderId])
  @@index([complexId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String
  totpSecret   String?
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Cart + Order
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String
  complexId  String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  customer Customer   @relation(fields: [customerId], references: [id])
  complex  Complex    @relation(fields: [complexId], references: [id])
  items    CartItem[]

  @@index([customerId])
}

model CartItem {
  id             String  @id @default(cuid())
  cartId         String
  outletId       String
  itemId         String
  qty            Int
  modifiers      Json
  notes          String?
  unitPriceCents Int

  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])

  @@index([cartId])
}

model Order {
  id                 String   @id @default(cuid())
  customerId         String
  complexId          String
  addressId          String
  status             String   @default("received")
  foodSubtotalCents  Int
  deliveryFeeCents   Int
  serviceFeeCents    Int
  tipCents           Int      @default(0)
  totalCents         Int
  surgeMultiplier    Float    @default(1.0)
  mallPassApplied    Boolean  @default(false)
  paymentIntentId    String?
  placedAt           DateTime @default(now())
  promisedDeliveryAt DateTime?

  customer  Customer   @relation(fields: [customerId], references: [id])
  complex   Complex    @relation(fields: [complexId], references: [id])
  address   Address    @relation(fields: [addressId], references: [id])
  subOrders SubOrder[]
  trip      Trip?

  @@index([customerId])
  @@index([complexId])
  @@index([status])
}

model SubOrder {
  id                String    @id @default(cuid())
  orderId           String
  outletId          String
  status            String    @default("pending")
  prepStartAt       DateTime?
  readyByAt         DateTime?
  readyAt           DateTime?
  riderCollectedAt  DateTime?
  pickupCode        String?
  foodSubtotalCents Int
  commissionCents   Int

  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  outlet     Outlet      @relation(fields: [outletId], references: [id])
  orderItems OrderItem[]
  tripStops  TripStop[]

  @@index([orderId])
  @@index([outletId])
  @@index([status])
}

model OrderItem {
  id             String  @id @default(cuid())
  subOrderId     String
  itemId         String
  qty            Int
  modifiers      Json
  notes          String?
  unitPriceCents Int
  totalCents     Int

  subOrder SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id])

  @@index([subOrderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Dispatch
// ─────────────────────────────────────────────────────────────────────────────

model Trip {
  id                 String    @id @default(cuid())
  orderId            String    @unique
  riderId            String
  status             String    @default("claimed")
  claimedAt          DateTime  @default(now())
  pickupStartedAt    DateTime?
  deliveryStartedAt  DateTime?
  deliveredAt        DateTime?
  distanceKm         Float?
  earningsCents      Int?

  order Order      @relation(fields: [orderId], references: [id])
  rider Rider      @relation(fields: [riderId], references: [id])
  stops TripStop[]

  @@index([riderId])
  @@index([status])
}

model TripStop {
  id          String    @id @default(cuid())
  tripId      String
  subOrderId  String
  sequence    Int
  etaAt       DateTime
  arrivedAt   DateTime?
  collectedAt DateTime?

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  subOrder SubOrder @relation(fields: [subOrderId], references: [id])

  @@unique([tripId, sequence])
  @@index([tripId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payouts
// ─────────────────────────────────────────────────────────────────────────────

model PayoutRun {
  id        String   @id @default(cuid())
  runDate   DateTime
  kind      String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  lines PayoutLine[]
}

model PayoutLine {
  id          String @id @default(cuid())
  payoutRunId String
  partyId     String
  amountCents Int
  ref         String?

  run PayoutRun @relation(fields: [payoutRunId], references: [id], onDelete: Cascade)

  @@index([payoutRunId])
  @@index([partyId])
}
